# XinYu Backend — environment configuration template
# Copy this file to .env and fill in the values.
# .env is git-ignored; never commit real credentials.

# ── Database ──────────────────────────────────────────────────────────────────
XINYU_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/xinyu

# ── Application ───────────────────────────────────────────────────────────────
XINYU_ENVIRONMENT=development
XINYU_DEBUG=true
XINYU_LOG_LEVEL=INFO

# ── Doubao LLM (Volcengine Ark) ───────────────────────────────────────────────
# Leave blank to use FakeLLMProvider (no network calls, deterministic output).
# Model in use: Doubao-Seed-2.0-pro (endpoint ID from Ark console)
XINYU_DOUBAO_API_KEY=
XINYU_DOUBAO_MODEL=
XINYU_DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── NLP model ─────────────────────────────────────────────────────────────────
# Absolute or relative path to a trained model directory produced by
# nlp/train/train_multitask.py (e.g. nlp/artifacts/roberta-domain).
# Leave blank to use StubNLPService (starts without torch/transformers).
XINYU_NLP_MODEL_PATH=
